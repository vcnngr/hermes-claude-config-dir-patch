+    default_dir = resolve_claude_config_dir(Path.home() / ".claude")
+    if resolved == default_dir:
+        return "claude_code"
+    return f"claude_code:{hashlib.sha256(str(resolved).encode('utf-8')).hexdigest()[:8]}"
