+def _entry(config_dir="/tmp/test-claude-account"):
+    return PooledCredential.from_dict(
+        "anthropic",
+        {
+            "id": "entry-test",
+            "label": "test",
+            "auth_type": "oauth",
+            "priority": 0,
+            "source": "claude_code:test",
+            "access_token": "test-token",
+            "claude_config_dir": config_dir,
+        },
+    )
+
+
+def _make_agent(**kwargs):
+    return run_agent.AIAgent(
+        api_key="test-token",
+        base_url="acp://claude-code",
+        provider="anthropic",
+        api_mode="claude_code",
+        model="claude-test",
+        quiet_mode=True,
+        skip_context_files=True,
+        skip_memory=True,
+        **kwargs,
