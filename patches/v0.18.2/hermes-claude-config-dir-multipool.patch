new file mode 100644
index 0000000..fd778c5
--- /dev/null
+++ b/agent/claude_code_cli_client.py
@@ -0,0 +1,214 @@
+"""OpenAI-compatible facade backed by the official ``claude -p`` CLI."""
+
+from __future__ import annotations
+
+import json
+import os
+import shutil
+import subprocess
+import threading
+from pathlib import Path
+from types import SimpleNamespace
+from typing import Any
+
+from agent.copilot_acp_client import _completion_to_stream_chunks
+from tools.environments.local import hermes_subprocess_env
+
+
+CLAUDE_CODE_MARKER_BASE_URL = "acp://claude-code"
+_DEFAULT_TIMEOUT_SECONDS = 900.0
+
+
+class ClaudeCodeCLIError(RuntimeError):
+    def __init__(self, message: str, *, status_code: int = 500):
+        super().__init__(message)
+        self.status_code = status_code
+
+
+def _render_content(content: Any) -> str:
+    if isinstance(content, str):
+        return content.strip()
+    if isinstance(content, list):
+        parts = []
+        for item in content:
+            if isinstance(item, str):
+                parts.append(item)
+            elif isinstance(item, dict) and isinstance(item.get("text"), str):
+                parts.append(item["text"])
+        return "\n".join(parts).strip()
+    if content is None:
+        return ""
+    return json.dumps(content, ensure_ascii=False)
+
+
+def _format_prompt(messages: list[dict[str, Any]]) -> str:
+    transcript = []
+    for message in messages:
+        if not isinstance(message, dict):
+            continue
+        text = _render_content(message.get("content"))
+        if text:
+            transcript.append(f"{str(message.get('role') or 'context').upper()}:\n{text}")
+    return (
+        "Continue this Hermes conversation. Follow system instructions and answer the latest user.\n\n"
+        + "\n\n".join(transcript)
+    )
+
+
+def _status_for_error(text: str) -> int:
+    lower = text.lower()
+    if any(term in lower for term in ("rate limit", "usage limit", "hit your limit", "limit reached", "resets at")):
+        return 429
+    if any(term in lower for term in ("not logged in", "authentication", "unauthorized", "invalid token")):
+        return 401
+    return 500
+
+
+class _ChatCompletions:
+    def __init__(self, client: "ClaudeCodeCLIClient"):
+        self._client = client
+
+    def create(self, **kwargs: Any) -> Any:
+        return self._client._create_chat_completion(**kwargs)
+
+
+class _Chat:
+    def __init__(self, client: "ClaudeCodeCLIClient"):
+        self.completions = _ChatCompletions(client)
+
+
+class ClaudeCodeCLIClient:
+    """Run each Hermes model turn through official Claude Code."""
+
+    def __init__(
+        self,
+        *,
+        api_key: str | None = None,
+        base_url: str | None = None,
+        claude_config_dir: str | None = None,
+        timeout: Any = None,
+        **_: Any,
+    ):
+        self.api_key = api_key or "claude-code-cli"
+        self.base_url = base_url or CLAUDE_CODE_MARKER_BASE_URL
+        self.claude_config_dir = str(Path(claude_config_dir or "~/.claude").expanduser().resolve())
+        self.timeout = timeout
+        self.chat = _Chat(self)
+        self.is_closed = False
+        self._active_process: subprocess.Popen[str] | None = None
+        self._lock = threading.Lock()
+
+    def close(self) -> None:
+        with self._lock:
+            proc = self._active_process
+            self._active_process = None
+        self.is_closed = True
+        if proc and proc.poll() is None:
+            proc.terminate()
+
+    def _subprocess_env(self) -> dict[str, str]:
+        env = hermes_subprocess_env(inherit_credentials=True)
+        for key in ("ANTHROPIC_API_KEY", "ANTHROPIC_AUTH_TOKEN", "ANTHROPIC_TOKEN", "CLAUDE_CODE_OAUTH_TOKEN", "CLAUDECODE"):
+            env.pop(key, None)
+        env["CLAUDE_CONFIG_DIR"] = self.claude_config_dir
+        env.setdefault("HOME", os.path.expanduser("~"))
+        return env
+
+    def _effective_timeout(self, timeout: Any) -> float:
+        value = timeout if timeout is not None else self.timeout
+        if isinstance(value, (int, float)) and value > 0:
+            return float(value)
+        candidates = [getattr(value, key, None) for key in ("read", "write", "connect", "pool")]
+        numeric = [float(item) for item in candidates if isinstance(item, (int, float)) and item > 0]
+        return max(numeric) if numeric else _DEFAULT_TIMEOUT_SECONDS
+
+    def _run(self, prompt: str, *, model: str, timeout: float) -> dict[str, Any]:
+        command = shutil.which("claude")
+        if not command:
+            raise ClaudeCodeCLIError("Claude Code CLI not found", status_code=503)
+        args = [
+            command,
+            "-p",
+            prompt,
+            "--model",
+            model,
+            "--output-format",
+            "json",
+            "--no-session-persistence",
+        ]
+        proc = subprocess.Popen(
+            args,
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+            text=True,
+            cwd=os.getcwd(),
+            env=self._subprocess_env(),
+        )
+        self.is_closed = False
+        with self._lock:
+            self._active_process = proc
+        try:
+            stdout, stderr = proc.communicate(timeout=timeout)
+        except subprocess.TimeoutExpired as exc:
+            proc.kill()
+            proc.communicate()
+            raise ClaudeCodeCLIError("Claude Code CLI timed out", status_code=504) from exc
+        finally:
+            with self._lock:
+                if self._active_process is proc:
+                    self._active_process = None
+
+        payload = None
+        for line in reversed(stdout.splitlines()):
+            try:
+                candidate = json.loads(line)
+            except Exception:
+                continue
+            if isinstance(candidate, dict):
+                payload = candidate
+                break
+        if payload is None:
+            message = (stderr or stdout or "Claude Code CLI returned no JSON").strip()
+            raise ClaudeCodeCLIError(message[:1000], status_code=_status_for_error(message))
+        if proc.returncode != 0 or payload.get("is_error"):
+            message = str(payload.get("result") or stderr or "Claude Code CLI failed")
+            raise ClaudeCodeCLIError(message[:1000], status_code=int(payload.get("api_error_status") or _status_for_error(message)))
+        return payload
+
+    def _create_chat_completion(
+        self,
+        *,
+        model: str | None = None,
+        messages: list[dict[str, Any]] | None = None,
+        timeout: Any = None,
+        stream: bool = False,
+        **_: Any,
+    ) -> Any:
+        selected_model = model or "claude-sonnet-4-6"
+        payload = self._run(
+            _format_prompt(messages or []),
+            model=selected_model,
+            timeout=self._effective_timeout(timeout),
+        )
+        usage_data = payload.get("usage") or {}
+        prompt_tokens = int(usage_data.get("input_tokens") or 0)
+        completion_tokens = int(usage_data.get("output_tokens") or 0)
+        usage = SimpleNamespace(
+            prompt_tokens=prompt_tokens,
+            completion_tokens=completion_tokens,
+            total_tokens=prompt_tokens + completion_tokens,
+            prompt_tokens_details=SimpleNamespace(cached_tokens=int(usage_data.get("cache_read_input_tokens") or 0)),
+        )
+        message = SimpleNamespace(
+            content=str(payload.get("result") or ""),
+            tool_calls=None,
+            reasoning=None,
+            reasoning_content=None,
+            reasoning_details=None,
+        )
+        completion = SimpleNamespace(
+            choices=[SimpleNamespace(message=message, finish_reason="stop")],
+            usage=usage,
+            model=selected_model,
+        )
+        return _completion_to_stream_chunks(completion) if stream else completion
