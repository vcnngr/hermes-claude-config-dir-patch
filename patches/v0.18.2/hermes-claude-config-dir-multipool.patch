+"""Claude Code external-agent runtime.
+
+This path bypasses Hermes' model/tool loop.  Claude Code receives the complete
+turn, executes Bash/file/MCP tools itself, and emits a stream that Hermes only
+displays and persists.  This ownership boundary prevents double execution.
+"""
+
+from __future__ import annotations
+
+import logging
+import os
+from typing import Any, Dict, List
+
+
+logger = logging.getLogger(__name__)
+
+
+def _as_nonnegative_int(value: Any) -> int:
+    try:
+        return max(int(value or 0), 0)
+    except (TypeError, ValueError):
+        return 0
+
+
+def _selected_claude_config_dir(agent) -> str:
+    configured = str(
+        (getattr(agent, "_client_kwargs", {}) or {}).get("claude_config_dir") or ""
+    ).strip()
+    if configured:
+        return configured
+
+    pool = getattr(agent, "_credential_pool", None)
+    if pool is not None:
+        entry = pool.current() or pool.peek()
+        config_dir = str(getattr(entry, "claude_config_dir", None) or "").strip()
+        if config_dir:
+            return config_dir
+    return "~/.claude"
+
+
+def _selected_claude_setup_token(config_dir: str) -> str:
+    """Return only the long-lived token bound to the selected config dir."""
+    try:
+        from agent.anthropic_adapter import (
+            is_claude_code_token_valid,
+            read_claude_code_setup_token,
+        )
+
+        creds = read_claude_code_setup_token(config_dir)
+        if creds and is_claude_code_token_valid(creds):
+            return str(creds.get("accessToken") or "").strip()
+    except Exception:
+        logger.debug("Could not read selected Claude setup-token", exc_info=True)
+    return ""
+
+
+def _compose_claude_delivery_text(turn) -> str:
+    """Return the complete user-facing text emitted during one Claude turn.
+
+    Claude Code's terminal ``result`` event contains only the final assistant
+    block.  In a multi-step turn Claude can write the substantive answer,
+    invoke a control tool such as ``ScheduleWakeup``, then finish with a short
+    acknowledgement (for example, "Waiting").  Returning only ``final_text``
+    drops the answer even though the earlier assistant event was persisted.
+
+    Standalone assistant messages are user-facing output.  Text attached to a
+    tool call is usually an execution preamble, so keep the established
+    terminal-result behaviour unless a distinct standalone answer exists.
+    """
+    terminal = str(getattr(turn, "final_text", "") or "").strip()
+    parts: list[str] = []
+
+    for message in getattr(turn, "projected_messages", None) or []:
+        if not isinstance(message, dict) or message.get("role") != "assistant":
+            continue
+        if message.get("tool_calls"):
+            continue
+        content = message.get("content")
+        if not isinstance(content, str):
+            continue
+        text = content.strip()
+        if not text or text == terminal or text in parts:
+            continue
+        # Some Claude CLI versions may already aggregate prior assistant text
+        # into the result event.  Do not prepend it a second time.
+        if terminal and text in terminal:
+            continue
+        parts.append(text)
+
+    if terminal:
+        parts.append(terminal)
+    return "\n\n".join(parts)
+
+
+def _record_claude_usage(agent, turn, *, api_calls: int) -> dict[str, Any]:
+    agent.session_api_calls += api_calls
+    usage = turn.token_usage if isinstance(turn.token_usage, dict) else {}
+    if not usage:
+        return {}
+
+    from agent.usage_pricing import CanonicalUsage, estimate_usage_cost
+
+    canonical = CanonicalUsage(
+        input_tokens=_as_nonnegative_int(usage.get("input_tokens")),
+        output_tokens=_as_nonnegative_int(usage.get("output_tokens")),
+        cache_read_tokens=_as_nonnegative_int(
+            usage.get("cache_read_input_tokens") or usage.get("cache_read_tokens")
+        ),
+        cache_write_tokens=_as_nonnegative_int(
+            usage.get("cache_creation_input_tokens") or usage.get("cache_write_tokens")
+        ),
+        reasoning_tokens=0,
+        raw_usage=usage,
+    )
+    prompt_tokens = canonical.prompt_tokens
+    completion_tokens = canonical.output_tokens
+    total_tokens = canonical.total_tokens
+    usage_dict = {
+        "prompt_tokens": prompt_tokens,
+        "completion_tokens": completion_tokens,
+        "total_tokens": total_tokens,
+        "input_tokens": canonical.input_tokens,
+        "output_tokens": canonical.output_tokens,
+        "cache_read_tokens": canonical.cache_read_tokens,
+        "cache_write_tokens": canonical.cache_write_tokens,
+        "reasoning_tokens": 0,
+    }
+
+    compressor = getattr(agent, "context_compressor", None)
+    if compressor is not None:
+        try:
+            compressor.update_from_response(usage_dict)
+        except Exception:
+            logger.debug("Claude Code usage update failed", exc_info=True)
+
+    agent.session_prompt_tokens += prompt_tokens
+    agent.session_completion_tokens += completion_tokens
+    agent.session_total_tokens += total_tokens
+    agent.session_input_tokens += canonical.input_tokens
+    agent.session_output_tokens += canonical.output_tokens
+    agent.session_cache_read_tokens += canonical.cache_read_tokens
+    agent.session_cache_write_tokens += canonical.cache_write_tokens
+
+    cost_result = estimate_usage_cost(
+        agent.model,
+        canonical,
+        provider=agent.provider,
+        base_url=agent.base_url,
+        api_key=getattr(agent, "api_key", ""),
+    )
+    if cost_result.amount_usd is not None:
+        agent.session_estimated_cost_usd += float(cost_result.amount_usd)
+    agent.session_cost_status = cost_result.status
+    agent.session_cost_source = cost_result.source
+
+    if agent._session_db and agent.session_id:
+        try:
+            if not agent._session_db_created:
+                agent._ensure_db_session()
+            agent._session_db.update_token_counts(
+                agent.session_id,
+                input_tokens=canonical.input_tokens,
+                output_tokens=canonical.output_tokens,
+                cache_read_tokens=canonical.cache_read_tokens,
+                cache_write_tokens=canonical.cache_write_tokens,
+                reasoning_tokens=0,
+                estimated_cost_usd=float(cost_result.amount_usd)
+                if cost_result.amount_usd is not None
+                else None,
+                cost_status=cost_result.status,
+                cost_source=cost_result.source,
+                billing_provider=agent.provider,
+                billing_base_url=agent.base_url,
+                billing_mode="subscription_included",
+                model=agent.model,
+                api_call_count=api_calls,
+            )
+        except Exception:
+            logger.debug("Claude Code token persistence failed", exc_info=True)
+
+    return {
+        **usage_dict,
+        "last_prompt_tokens": prompt_tokens,
+        "estimated_cost_usd": float(cost_result.amount_usd)
+        if cost_result.amount_usd is not None
+        else None,
+        "cost_status": cost_result.status,
+        "cost_source": cost_result.source,
+    }
+
+
+def run_claude_code_turn(
+    agent,
+    *,
+    user_message: str,
+    original_user_message: Any,
+    messages: List[Dict[str, Any]],
+    active_system_prompt: str,
+    effective_task_id: str,
+    should_review_memory: bool = False,
+) -> Dict[str, Any]:
+    from agent.runtime_cwd import resolve_agent_cwd
+    from agent.transports.claude_code_session import (
+        ClaudeCodeSession,
+        build_turn_prompt,
+    )
+
+    cwd = getattr(agent, "session_cwd", None) or str(resolve_agent_cwd())
+    permission_mode = os.environ.get(
+        "HERMES_CLAUDE_PERMISSION_MODE", "auto"
+    ).strip() or "auto"
+    expose_hermes_tools = os.environ.get(
+        "HERMES_CLAUDE_HERMES_TOOLS", "1"
+    ).strip().lower() not in {"0", "false", "no", "off"}
+
+    def _on_text_delta(text: str) -> None:
+        agent._touch_activity("receiving Claude Code stream")
+        agent._fire_stream_delta(text)
+
+    def _on_reasoning_delta(text: str) -> None:
+        agent._touch_activity("receiving Claude Code reasoning")
+        agent._fire_reasoning_delta(text)
+
+    def _on_tool_started(name: str, args: dict[str, Any]) -> None:
+        agent._touch_activity(f"Claude Code executing tool: {name}")
+        agent._fire_tool_gen_started(name)
+        if agent.stream_delta_callback:
+            try:
+                agent.stream_delta_callback(None)
+            except Exception:
+                pass
+        callback = getattr(agent, "tool_progress_callback", None)
+        if callback is not None:
+            try:
+                callback("tool.started", name, name, args)
+            except Exception:
+                logger.debug("Claude tool-start callback failed", exc_info=True)
+
+    def _on_tool_completed(name: str) -> None:
+        agent._touch_activity(f"Claude Code completed tool: {name}")
+        callback = getattr(agent, "tool_progress_callback", None)
+        if callback is not None:
+            try:
+                callback("tool.completed", name, None, None)
+            except Exception:
+                logger.debug("Claude tool-complete callback failed", exc_info=True)
+
+    def _on_status(text: str) -> None:
+        agent._touch_activity(text)
+        try:
+            agent._emit_status(text)
+        except Exception:
+            logger.debug("Claude status callback failed", exc_info=True)
+
+    prompt = build_turn_prompt(
+        system_prompt=active_system_prompt or "",
+        messages=messages,
+    )
+    pool = getattr(agent, "_credential_pool", None)
+    pool_size = len(pool.entries()) if pool is not None else 1
+    max_attempts = max(pool_size, 1)
+    has_retried_429 = False
+    attempts = 0
+    turn = None
+    tried_dirs: set[str] = set()
+
+    while attempts < max_attempts:
+        config_dir = _selected_claude_config_dir(agent)
+        setup_token = _selected_claude_setup_token(config_dir)
+        if config_dir in tried_dirs:
+            break
+        tried_dirs.add(config_dir)
+        attempts += 1
+
+        session = ClaudeCodeSession(
+            claude_config_dir=config_dir,
+            oauth_token=setup_token,
+            cwd=cwd,
+            model=agent.model,
+            permission_mode=permission_mode,
+            expose_hermes_tools=expose_hermes_tools,
+            enabled_toolsets=getattr(agent, "enabled_toolsets", None),
+            disabled_toolsets=getattr(agent, "disabled_toolsets", None),
+            on_text_delta=_on_text_delta,
+            on_reasoning_delta=_on_reasoning_delta,
+            on_tool_started=_on_tool_started,
+            on_tool_completed=_on_tool_completed,
+            on_status=_on_status,
+        )
+        agent._claude_code_session = session
+        try:
+            turn = session.run_turn(prompt=prompt)
+        finally:
+            session.close()
+            if getattr(agent, "_claude_code_session", None) is session:
+                agent._claude_code_session = None
+
+        if turn.error is None or turn.interrupted:
+            break
+        if turn.status_code not in {401, 429}:
+            break
+        # A retry replays the whole turn in another Claude process. Never do
+        # that after a native tool started: Bash/Edit/MCP side effects may
+        # already have happened even when the provider later returned 401/429.
+        if turn.side_effects_possible:
+            _on_status("Claude credential failed after tool execution; not replaying turn")
+            break
+
+        recovered, has_retried_429 = agent._recover_with_credential_pool(
+            status_code=turn.status_code,
+            has_retried_429=has_retried_429,
+            error_context={
+                "message": turn.error,
+                "reason": "claude_code_runtime",
+            },
+        )
+        if not recovered:
+            break
+        _on_status("Claude credential rotated; retrying turn")
+
+    if turn is None:
+        return {
+            "final_response": "Claude Code runtime could not select a credential.",
+            "messages": messages,
+            "api_calls": attempts,
+            "completed": False,
+            "partial": True,
+            "error": "no Claude Code credential available",
+            "agent_persisted": True,
+        }
+
+    delivery_text = (
+        _compose_claude_delivery_text(turn)
+        if turn.error is None
+        else turn.final_text
+    )
+
+    if turn.projected_messages:
+        messages.extend(turn.projected_messages)
+    if turn.final_text and not any(
+        msg.get("role") == "assistant" and msg.get("content") == turn.final_text
+        for msg in turn.projected_messages[-2:]
+        if isinstance(msg, dict)
+    ):
+        messages.append({"role": "assistant", "content": turn.final_text})
+
+    if getattr(agent, "_session_db", None) is not None:
+        try:
+            agent._flush_messages_to_session_db(messages)
+        except Exception:
+            logger.debug("Claude projected-message flush failed", exc_info=True)
+
+    agent._iters_since_skill = (
+        getattr(agent, "_iters_since_skill", 0) + turn.tool_iterations
+    )
+    should_review_skills = False
+    if (
+        agent._skill_nudge_interval > 0
+        and agent._iters_since_skill >= agent._skill_nudge_interval
+        and "skill_manage" in agent.valid_tool_names
+    ):
+        should_review_skills = True
+        agent._iters_since_skill = 0
+
+    if not turn.interrupted and turn.error is None:
+        try:
+            agent._sync_external_memory_for_turn(
+                original_user_message=original_user_message,
+                final_response=delivery_text,
+                interrupted=False,
+                messages=messages,
+            )
+        except Exception:
+            logger.debug("Claude external memory sync failed", exc_info=True)
+
+    if (
+        delivery_text
+        and not turn.interrupted
+        and turn.error is None
+        and (should_review_memory or should_review_skills)
+    ):
+        try:
+            agent._spawn_background_review(
+                messages_snapshot=list(messages),
+                review_memory=should_review_memory,
+                review_skills=should_review_skills,
+            )
+        except Exception:
+            logger.debug("Claude background review failed", exc_info=True)
+
+    usage_result = _record_claude_usage(agent, turn, api_calls=attempts)
+    final_response = delivery_text or (turn.error or "")
+    return {
+        "final_response": final_response,
+        "messages": messages,
+        "api_calls": attempts,
+        "completed": not turn.interrupted and turn.error is None,
+        "partial": turn.interrupted or turn.error is not None,
+        "error": turn.error,
+        "agent_persisted": True,
+        "claude_session_id": turn.session_id,
+        **usage_result,
+    }
+
+
+__all__ = ["run_claude_code_turn"]
