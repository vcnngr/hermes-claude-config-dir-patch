@@ -0,0 +1,563 @@
+"""Streaming Claude Code runtime for Hermes.
+
+Claude Code owns the agent loop and executes its native tools.  This module
+only transports one Hermes turn to ``claude -p``, streams progress back to
+Hermes, and projects completed Claude messages into Hermes' transcript shape.
+Projected tool calls are history records; callers must never dispatch them
+through Hermes' tool executor a second time.
+"""
+
+from __future__ import annotations
+
+import json
+import logging
+import os
+import queue
+import shutil
+import subprocess
+import sys
+import threading
+import time
+from collections import deque
+from dataclasses import dataclass, field
+from pathlib import Path
+from typing import Any, Callable, Optional
+
+from agent.redact import redact_sensitive_text
+from tools.environments.local import hermes_subprocess_env
+
+
+logger = logging.getLogger(__name__)
+
+_DEFAULT_TURN_TIMEOUT = 900.0
+_STDERR_TAIL_LINES = 80
+
+
+def _status_for_error(text: str) -> int:
+    lower = (text or "").lower()
+    if any(
+        term in lower
+        for term in (
+            "rate limit",
+            "usage limit",
+            "hit your limit",
+            "limit reached",
+            "resets at",
+            "error_max_budget",
+        )
+    ):
+        return 429
+    if any(
+        term in lower
+        for term in (
+            "not logged in",
+            "authentication",
+            "unauthorized",
+            "invalid token",
+            "oauth session expired",
+            "could not be refreshed",
+        )
+    ):
+        return 401
+    return 500
+
+
+def _render_content(content: Any, *, limit: int = 12000) -> str:
+    if isinstance(content, str):
+        return content[:limit]
+    if isinstance(content, list):
+        parts: list[str] = []
+        for item in content:
+            if isinstance(item, str):
+                parts.append(item)
+            elif isinstance(item, dict):
+                text = item.get("text")
+                if isinstance(text, str):
+                    parts.append(text)
+                elif item.get("type") == "tool_result":
+                    parts.append(_render_content(item.get("content"), limit=limit))
+        return "\n".join(parts)[:limit]
+    if content is None:
+        return ""
+    try:
+        return json.dumps(content, ensure_ascii=False)[:limit]
+    except (TypeError, ValueError):
+        return str(content)[:limit]
+
+
+def build_turn_prompt(
+    *,
+    system_prompt: str,
+    messages: list[dict[str, Any]],
+) -> str:
+    """Build a bounded, role-labelled prompt and send it over stdin.
+
+    stdin keeps profile instructions and conversation data out of the process
+    command line.  ``messages`` has already passed Hermes compression before
+    this function runs.
+    """
+    sections = [
+        "Continue this Hermes conversation and complete the latest user request. "
+        "Operate autonomously with Claude Code tools when useful.\n",
+    ]
+    if system_prompt:
+        sections.append(f"HERMES SYSTEM INSTRUCTIONS:\n{system_prompt}\n")
+
+    transcript: list[str] = []
+    for message in messages:
+        if not isinstance(message, dict):
+            continue
+        role = str(message.get("role") or "context").upper()
+        text = _render_content(message.get("content"))
+        tool_calls = message.get("tool_calls") or []
+        if tool_calls:
+            names: list[str] = []
+            for call in tool_calls:
+                if not isinstance(call, dict):
+                    continue
+                fn = call.get("function") or {}
+                if isinstance(fn, dict) and fn.get("name"):
+                    names.append(str(fn["name"]))
+            if names:
+                suffix = f"[completed tool calls in prior context: {', '.join(names)}]"
+                text = f"{text}\n{suffix}" if text else suffix
+        if text:
+            transcript.append(f"{role}:\n{text}")
+    if transcript:
+        sections.append("CONVERSATION TRANSCRIPT:\n" + "\n\n".join(transcript))
+    return "\n\n".join(sections)
+
+
+def _tool_result_text(block: dict[str, Any]) -> str:
+    text = _render_content(block.get("content"), limit=16000)
+    if block.get("is_error"):
+        return f"[error]\n{text}" if text else "[error]"
+    return text
+
+
+@dataclass
+class ClaudeTurnResult:
+    final_text: str = ""
+    projected_messages: list[dict[str, Any]] = field(default_factory=list)
+    token_usage: dict[str, Any] = field(default_factory=dict)
+    session_id: Optional[str] = None
+    tool_iterations: int = 0
+    error: Optional[str] = None
+    status_code: Optional[int] = None
+    interrupted: bool = False
+    should_retire: bool = False
+    side_effects_possible: bool = False
+
+
+class ClaudeEventProjector:
+    """Project complete Claude SDK messages into Hermes transcript entries."""
+
+    def __init__(self) -> None:
+        self._tool_names: dict[str, str] = {}
+
+    def tool_name(self, tool_use_id: str) -> str:
+        return self._tool_names.get(tool_use_id, "ClaudeTool")
+
+    def project(self, payload: dict[str, Any]) -> tuple[list[dict[str, Any]], int]:
+        kind = payload.get("type")
+        message = payload.get("message") or {}
+        if not isinstance(message, dict):
+            return [], 0
+        content = message.get("content") or []
+        if not isinstance(content, list):
+            content = [{"type": "text", "text": _render_content(content)}]
+
+        if kind == "assistant":
+            text_parts: list[str] = []
+            calls: list[dict[str, Any]] = []
+            for block in content:
+                if not isinstance(block, dict):
+                    continue
+                block_type = block.get("type")
+                if block_type == "text" and isinstance(block.get("text"), str):
+                    text_parts.append(block["text"])
+                elif block_type == "tool_use":
+                    call_id = str(block.get("id") or "")
+                    name = str(block.get("name") or "ClaudeTool")
+                    if call_id:
+                        self._tool_names[call_id] = name
+                    args = block.get("input") or {}
+                    try:
+                        arg_text = json.dumps(args, ensure_ascii=False, sort_keys=True)
+                    except (TypeError, ValueError):
+                        arg_text = json.dumps({"input": str(args)}, ensure_ascii=False)
+                    calls.append(
+                        {
+                            "id": call_id or f"claude_tool_{len(calls)}",
+                            "type": "function",
+                            "function": {"name": name, "arguments": arg_text},
+                        }
+                    )
+            if not text_parts and not calls:
+                return [], 0
+            projected: dict[str, Any] = {
+                "role": "assistant",
+                "content": "\n".join(text_parts) or None,
+            }
+            if calls:
+                projected["tool_calls"] = calls
+            return [projected], 0
+
+        if kind == "user":
+            messages: list[dict[str, Any]] = []
+            for block in content:
+                if not isinstance(block, dict) or block.get("type") != "tool_result":
+                    continue
+                call_id = str(block.get("tool_use_id") or "")
+                messages.append(
+                    {
+                        "role": "tool",
+                        "name": self.tool_name(call_id),
+                        "tool_name": self.tool_name(call_id),
+                        "tool_call_id": call_id,
+                        "content": _tool_result_text(block),
+                    }
+                )
+            return messages, len(messages)
+
+        return [], 0
+
+
+class ClaudeCodeSession:
+    """One active Claude Code subprocess at a time, owned by an AIAgent turn."""
+
+    def __init__(
+        self,
+        *,
+        claude_config_dir: str,
+        oauth_token: Optional[str] = None,
+        cwd: str,
+        model: str,
+        permission_mode: str = "auto",
+        expose_hermes_tools: bool = True,
+        enabled_toolsets: Optional[list[str]] = None,
+        disabled_toolsets: Optional[list[str]] = None,
+        claude_bin: str = "claude",
+        on_text_delta: Optional[Callable[[str], None]] = None,
+        on_reasoning_delta: Optional[Callable[[str], None]] = None,
+        on_tool_started: Optional[Callable[[str, dict[str, Any]], None]] = None,
+        on_tool_completed: Optional[Callable[[str], None]] = None,
+        on_status: Optional[Callable[[str], None]] = None,
+    ) -> None:
+        self.claude_config_dir = str(Path(claude_config_dir).expanduser().resolve())
+        self.oauth_token = str(oauth_token or "").strip()
+        self.cwd = str(Path(cwd).expanduser().resolve())
+        self.model = model
+        self.permission_mode = permission_mode
+        self.expose_hermes_tools = expose_hermes_tools
+        self.enabled_toolsets = enabled_toolsets
+        self.disabled_toolsets = disabled_toolsets
+        self.claude_bin = claude_bin
+        self.on_text_delta = on_text_delta
+        self.on_reasoning_delta = on_reasoning_delta
+        self.on_tool_started = on_tool_started
+        self.on_tool_completed = on_tool_completed
+        self.on_status = on_status
+        self._active_process: Optional[subprocess.Popen[str]] = None
+        self._lock = threading.Lock()
+        self._interrupt_event = threading.Event()
+
+    def _environment(self) -> dict[str, str]:
+        env = hermes_subprocess_env(inherit_credentials=True)
+        for key in (
+            "ANTHROPIC_API_KEY",
+            "ANTHROPIC_AUTH_TOKEN",
+            "ANTHROPIC_TOKEN",
+            "CLAUDE_CODE_OAUTH_TOKEN",
+            "CLAUDECODE",
+            "ANTHROPIC_BASE_URL",
+            "ANTHROPIC_CUSTOM_HEADERS",
+            "CLAUDE_CODE_USE_BEDROCK",
+            "CLAUDE_CODE_USE_VERTEX",
+            "CLAUDE_CODE_USE_FOUNDRY",
+        ):
+            env.pop(key, None)
+        env["CLAUDE_CONFIG_DIR"] = self.claude_config_dir
+        if self.oauth_token:
+            env["CLAUDE_CODE_OAUTH_TOKEN"] = self.oauth_token
+        env.setdefault("HOME", os.path.expanduser("~"))
+        return env
+
+    def _hermes_mcp_config(self) -> str:
+        project_root = str(Path(__file__).resolve().parents[2])
+        server_env = {
+            "PYTHONPATH": project_root,
+            "HERMES_MCP_QUIET": "1",
+        }
+        hermes_home = os.environ.get("HERMES_HOME", "").strip()
+        if hermes_home:
+            server_env["HERMES_HOME"] = hermes_home
+        if self.enabled_toolsets is not None:
+            server_env["HERMES_EXTERNAL_ENABLED_TOOLSETS"] = json.dumps(
+                self.enabled_toolsets
+            )
+        if self.disabled_toolsets is not None:
+            server_env["HERMES_EXTERNAL_DISABLED_TOOLSETS"] = json.dumps(
+                self.disabled_toolsets
+            )
+        return json.dumps(
+            {
+                "mcpServers": {
+                    "hermes-tools": {
+                        "command": sys.executable,
+                        "args": ["-m", "agent.transports.hermes_tools_mcp_server"],
+                        "env": server_env,
+                    }
+                }
+            },
+            ensure_ascii=False,
+        )
+
+    def _command(self) -> list[str]:
+        command = shutil.which(self.claude_bin)
+        if not command:
+            raise RuntimeError("Claude Code CLI not found")
+        args = [
+            command,
+            "-p",
+            "--model",
+            self.model,
+            "--output-format",
+            "stream-json",
+            "--verbose",
+            "--include-partial-messages",
+            "--no-session-persistence",
+            "--permission-mode",
+            self.permission_mode,
+            "--tools",
+            "default",
+        ]
+        if self.expose_hermes_tools:
+            args.extend(["--mcp-config", self._hermes_mcp_config()])
+        return args
+
+    def request_interrupt(self) -> None:
+        self._interrupt_event.set()
+        with self._lock:
+            proc = self._active_process
+        if proc is not None and proc.poll() is None:
+            try:
+                proc.terminate()
+            except Exception:
+                logger.debug("Claude Code terminate failed", exc_info=True)
+
+    def close(self) -> None:
+        with self._lock:
+            proc = self._active_process
+        if proc is not None and proc.poll() is None:
+            self.request_interrupt()
+
+    def run_turn(
+        self,
+        *,
+        prompt: str,
+        timeout: float = _DEFAULT_TURN_TIMEOUT,
+    ) -> ClaudeTurnResult:
+        result = ClaudeTurnResult()
+        projector = ClaudeEventProjector()
+        stdout_queue: queue.Queue[tuple[str, Optional[str]]] = queue.Queue()
+        stderr_tail: deque[str] = deque(maxlen=_STDERR_TAIL_LINES)
+        saw_result = False
+        self._interrupt_event.clear()
+
+        try:
+            proc = subprocess.Popen(
+                self._command(),
+                stdin=subprocess.PIPE,
+                stdout=subprocess.PIPE,
+                stderr=subprocess.PIPE,
+                text=True,
+                bufsize=1,
+                cwd=self.cwd,
+                env=self._environment(),
+            )
+        except Exception as exc:
+            result.error = f"Claude Code startup failed: {exc}"
+            result.status_code = 503
+            result.should_retire = True
+            return result
+
+        with self._lock:
+            self._active_process = proc
+
+        def _read_stdout() -> None:
+            try:
+                assert proc.stdout is not None
+                for line in proc.stdout:
+                    stdout_queue.put(("line", line))
+            finally:
+                stdout_queue.put(("eof", None))
+
+        def _read_stderr() -> None:
+            try:
+                assert proc.stderr is not None
+                for line in proc.stderr:
+                    stderr_tail.append(line.rstrip())
+            except Exception:
+                pass
+
+        stdout_thread = threading.Thread(target=_read_stdout, daemon=True)
+        stderr_thread = threading.Thread(target=_read_stderr, daemon=True)
+        stdout_thread.start()
+        stderr_thread.start()
+
+        try:
+            assert proc.stdin is not None
+            proc.stdin.write(prompt)
+            proc.stdin.close()
+        except Exception as exc:
+            self.request_interrupt()
+            result.error = f"Claude Code input failed: {exc}"
+            result.status_code = 500
+            result.should_retire = True
+
+        deadline = time.monotonic() + max(float(timeout), 1.0)
+        reached_eof = False
+        while not reached_eof and result.error is None:
+            if self._interrupt_event.is_set():
+                result.interrupted = True
+                break
+            if time.monotonic() >= deadline:
+                result.error = f"Claude Code turn timed out after {timeout:.0f}s"
+                result.status_code = 504
+                result.interrupted = True
+                result.should_retire = True
+                self.request_interrupt()
+                break
+            try:
+                item_type, raw_line = stdout_queue.get(timeout=0.25)
+            except queue.Empty:
+                if proc.poll() is not None and not stdout_thread.is_alive():
+                    reached_eof = True
+                continue
+            if item_type == "eof":
+                reached_eof = True
+                continue
+            if not raw_line or not raw_line.strip():
+                continue
+            try:
+                payload = json.loads(raw_line)
+            except json.JSONDecodeError:
+                logger.debug("Ignoring non-JSON Claude stdout line")
+                continue
+            if not isinstance(payload, dict):
+                continue
+
+            payload_type = payload.get("type")
+            if payload.get("session_id"):
+                result.session_id = str(payload["session_id"])
+
+            if payload_type == "stream_event":
+                event = payload.get("event") or {}
+                if not isinstance(event, dict):
+                    continue
+                event_type = event.get("type")
+                if event_type == "content_block_start":
+                    index = int(event.get("index") or 0)
+                    block = event.get("content_block") or {}
+                    if isinstance(block, dict) and block.get("type") == "tool_use":
+                        name = str(block.get("name") or "ClaudeTool")
+                        tool_id = str(block.get("id") or "")
+                        result.side_effects_possible = True
+                        if tool_id:
+                            projector._tool_names[tool_id] = name
+                        if self.on_tool_started is not None:
+                            self.on_tool_started(name, block.get("input") or {})
+                elif event_type == "content_block_delta":
+                    delta = event.get("delta") or {}
+                    if not isinstance(delta, dict):
+                        continue
+                    if delta.get("type") == "text_delta":
+                        text = delta.get("text") or ""
+                        if text and self.on_text_delta is not None:
+                            self.on_text_delta(text)
+                    elif delta.get("type") == "thinking_delta":
+                        thinking = delta.get("thinking") or ""
+                        if thinking and self.on_reasoning_delta is not None:
+                            self.on_reasoning_delta(thinking)
+                continue
+
+            if payload_type == "tool_progress":
+                if self.on_status is not None:
+                    name = str(payload.get("tool_name") or "tool")
+                    elapsed = payload.get("elapsed_time_seconds")
+                    suffix = (
+                        f" ({float(elapsed):.0f}s)"
+                        if isinstance(elapsed, (int, float))
+                        else ""
+                    )
+                    self.on_status(f"Claude {name} running{suffix}")
+                continue
+
+            if payload_type in {"assistant", "user"}:
+                projected, completed = projector.project(payload)
+                if projected:
+                    result.projected_messages.extend(projected)
+                result.tool_iterations += completed
+                if payload_type == "user" and completed and self.on_tool_completed:
+                    for message in projected:
+                        self.on_tool_completed(str(message.get("name") or "ClaudeTool"))
+                continue
+
+            if payload_type == "system" and payload.get("subtype") == "api_retry":
+                if self.on_status is not None:
+                    attempt = payload.get("attempt")
+                    maximum = payload.get("max_retries")
+                    category = payload.get("error") or "provider error"
+                    self.on_status(f"Claude retry {attempt}/{maximum}: {category}")
+                continue
+
+            if payload_type == "result":
+                saw_result = True
+                result.final_text = str(payload.get("result") or "")
+                usage = payload.get("usage") or {}
+                if isinstance(usage, dict):
+                    result.token_usage = usage
+                subtype = str(payload.get("subtype") or "")
+                if payload.get("is_error") or (subtype and subtype != "success"):
+                    result.error = result.final_text or f"Claude Code ended with {subtype}"
+                    result.status_code = int(
+                        payload.get("api_error_status")
+                        or _status_for_error(f"{subtype} {result.error}")
+                    )
+
+        try:
+            return_code = proc.wait(timeout=5)
+        except subprocess.TimeoutExpired:
+            proc.kill()
+            return_code = proc.wait(timeout=5)
+            result.should_retire = True
+        finally:
+            with self._lock:
+                if self._active_process is proc:
+                    self._active_process = None
+
+        stderr_text = "\n".join(stderr_tail).strip()
+        if self._interrupt_event.is_set() and result.error is None:
+            result.interrupted = True
+        elif return_code != 0 and result.error is None:
+            safe_error = redact_sensitive_text(
+                stderr_text or "Claude Code exited without a result", force=True
+            )
+            result.error = safe_error[-4000:]
+            result.status_code = _status_for_error(result.error)
+            result.should_retire = True
+        elif not saw_result and result.error is None:
+            result.error = "Claude Code stream ended without a result message"
+            result.status_code = 500
+            result.should_retire = True
+
+        return result
+
