+    monkeypatch.delenv("HERMES_ANTHROPIC_RUNTIME", raising=False)
+    resolved = _resolve_runtime_from_pool_entry(
+        provider="anthropic",
+        entry=_entry(),
+        requested_provider="anthropic",
+        model_cfg={"default": "claude-test", "provider": "anthropic"},
+    )
+
+    assert resolved["api_mode"] == "claude_code"
+    assert resolved["base_url"] == "acp://claude-code"
