+def claude_code_keychain_service(config_dir: Optional[Any] = None) -> str:
+    """Return Claude Code's config-scoped macOS Keychain service name."""
+    resolved = resolve_claude_config_dir(config_dir)
+    suffix = hashlib.sha256(str(resolved).encode("utf-8")).hexdigest()[:8]
+    return f"Claude Code-credentials-{suffix}"
+
+
+def claude_code_pool_source(config_dir: Optional[Any] = None) -> str:
+    """Return a stable pool source id, preserving the legacy default id."""
